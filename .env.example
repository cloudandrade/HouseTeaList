# Copia para `.env.local` na raiz do projeto e ajusta.

# --- API (Next) ---
NEXT_PUBLIC_API_URL=/api

# --- Tema fallback (1–30) ---
NEXT_PUBLIC_THEME_VARIATION=1

# --- MongoDB ---
APP_ENV=local
# MONGODB_URI=... (quando APP_ENV=prod)
# MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/tealist

# --- Admin da PLATAFORMA (criar eventos / tenants na API) ---
# Usa-se no cabeçalho HTTP `x-system-admin-key` em POST /api/sys/tenants
# e POST /api/sys/migrate-legacy (migração de dados antigos).
# CONFIG_ADMIN_KEY=
