# Depois de alterar, reinicia o servidor do Vite (npm start).
# Não coloques espaço antes do nome da variável.

# --- API ---
# Dev (recomendado): `/api` — o Vite (vite.config.js) envia para http://127.0.0.1:5000.
# Assim evitas “Cannot POST /admin/…” quando o pedido ia parar ao servidor do Vite (porta 3000).
# Build em produção com front e API em hosts diferentes: URL absoluta, ex. https://api.teudominio.com
VITE_API_URL=/api
# VITE_API_URL=http://localhost:5000

# --- Tema: número de 1 a 30 (ver themes.md e src/config/themePalettes.js) ---
VITE_THEME_VARIATION=1
