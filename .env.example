# Depois de alterar este ficheiro, reinicia o servidor do Vite (npm start / yarn dev).
# Não deixes linhas como VITE_COLOR_PRIMARY= sem valor — string vazia quebra o tema do Material-UI.
# Não coloques espaço antes do nome (ex.: " VITE_COLOR_PRIMARY=..." — o Vite não lê e ficam os fallbacks).
#
# IMPORTANTE — cores hex: usa aspas duplas, ex.: VITE_COLOR_PRIMARY="#2e7d32"
# Em ficheiros .env, # fora de aspas inicia comentário; VITE_COLOR_PRIMARY=#2e7d32 fica com valor
# vazio e o app usa os azuis por defeito em src/config/theme.js.
#
# --- API ---
VITE_API_URL=http://localhost:5000

# --- Tema (hex ou rgb) — todas opcionais; omissão = valores por defeito em src/config/theme.js ---
# Tom mais claro (checkbox vazio, um dos quadrantes do fundo xadrez)
VITE_COLOR_ACCENT=#f8bbd0

# Cor principal: botões, bordas, foco, área assinada (se omitires, usa o mesmo valor que ACCENT)
VITE_COLOR_PRIMARY=#f8bbd0

# Fundo de caixas (intro, acordeão aberto não assinado)
VITE_COLOR_SURFACE=#ffffff

# Padrão do body (conic-gradient em xadrez). Se omitires A, usa VITE_COLOR_ACCENT; se ambos faltarem, cinza neutro (não rosa).
VITE_COLOR_BACKGROUND_A=#f8bbd0
VITE_COLOR_BACKGROUND_B=#ffffff

# Texto geral / texto sobre fundo primary (assinaturas)
VITE_COLOR_TEXT=#212121
VITE_COLOR_TEXT_ON_PRIMARY=#ffffff

# --- Exemplos de paletas (copiar para cima e comentar a rosa) ---
#
# Azul + branco:
# VITE_COLOR_PRIMARY="#1565c0"
# VITE_COLOR_ACCENT="#90caf9"
# VITE_COLOR_SURFACE="#ffffff"
# VITE_COLOR_BACKGROUND_A="#e3f2fd"
# VITE_COLOR_BACKGROUND_B="#ffffff"
# VITE_COLOR_TEXT="#1a237e"
# VITE_COLOR_TEXT_ON_PRIMARY="#ffffff"
#
# Verde natural:
# VITE_COLOR_PRIMARY="#2e7d32"
# VITE_COLOR_ACCENT="#a5d6a7"
# VITE_COLOR_SURFACE="#fafafa"
# VITE_COLOR_BACKGROUND_A="#e8f5e9"
# VITE_COLOR_BACKGROUND_B="#ffffff"
# VITE_COLOR_TEXT="#1b5e20"
# VITE_COLOR_TEXT_ON_PRIMARY="#ffffff"
#
# Amarelo / âmbar:
# VITE_COLOR_PRIMARY="#f9a825"
# VITE_COLOR_ACCENT="#fff9c4"
# VITE_COLOR_SURFACE="#fffde7"
# VITE_COLOR_BACKGROUND_A="#fff9c4"
# VITE_COLOR_BACKGROUND_B="#ffffff"
# VITE_COLOR_TEXT="#4e342e"
# VITE_COLOR_TEXT_ON_PRIMARY="#3e2723"
#
# Marrom / creme:
# VITE_COLOR_PRIMARY="#5d4037"
# VITE_COLOR_ACCENT="#d7ccc8"
# VITE_COLOR_SURFACE="#efebe9"
# VITE_COLOR_BACKGROUND_A="#d7ccc8"
# VITE_COLOR_BACKGROUND_B="#faf8f6"
# VITE_COLOR_TEXT="#3e2723"
# VITE_COLOR_TEXT_ON_PRIMARY="#fff8e1"
#
# Preto + cinza (contraste alto):
# VITE_COLOR_PRIMARY="#212121"
# VITE_COLOR_ACCENT="#9e9e9e"
# VITE_COLOR_SURFACE="#fafafa"
# VITE_COLOR_BACKGROUND_A="#eeeeee"
# VITE_COLOR_BACKGROUND_B="#ffffff"
# VITE_COLOR_TEXT="#212121"
# VITE_COLOR_TEXT_ON_PRIMARY="#ffffff"
