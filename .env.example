# Copia para `.env.local` na raiz do projeto e ajusta.
# Depois de alterar variáveis NEXT_PUBLIC_*, reinicia `npm run dev`.

# --- API (Next: rotas em /api) ---
# Dev (recomendado): `/api` — mesmo host que o Next.
# Produção com API noutro host: URL absoluta, ex. https://api.teudominio.com
NEXT_PUBLIC_API_URL=/api
# NEXT_PUBLIC_API_URL=http://localhost:3000

# --- Tema: número de 1 a 30 (ver themes.md e src/config/themePalettes.js) ---
NEXT_PUBLIC_THEME_VARIATION=1

# --- MongoDB (servidor / rotas API) ---
# local | prod
APP_ENV=local

# Em prod (APP_ENV=prod), obrigatório — connection string do Atlas ou outro host remoto
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.xxxxx.mongodb.net/tealist?retryWrites=true&w=majority

# Opcional em local: sobrescreve o padrão mongodb://127.0.0.1:27017/tealist
# MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/tealist

# Chave para o painel /config — obrigatória para PUT/POST/DELETE admin.
# CONFIG_ADMIN_KEY=
