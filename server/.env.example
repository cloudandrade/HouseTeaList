# local | prod
APP_ENV=local

# Em prod (APP_ENV=prod), obrigatório — connection string do Atlas ou outro host remoto
# MONGODB_URI=mongodb+srv://usuario:senha@cluster.xxxxx.mongodb.net/tealist?retryWrites=true&w=majority

# Opcional em local: sobrescreve o padrão mongodb://127.0.0.1:27017/tealist
# (use mongodb://mongo:27017/tealist se a API rodar no mesmo Docker Compose que o serviço "mongo")
# MONGODB_URI_LOCAL=mongodb://127.0.0.1:27017/tealist

PORT=5000
